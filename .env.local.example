# Copy this file to .env.local and fill in your keys, then restart `npm run dev`.
# These are read ONLY server-side (the API routes) and never exposed to the browser.

# Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Etsy Open API v3 — keystring from https://www.etsy.com/developers/your-apps
ETSY_API_KEY=your_etsy_key_here
