# Copy this file to .env.local and fill in your keys, then restart `npm run dev`.
# These are read ONLY server-side (the API routes) and never exposed to the browser.

# Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Etsy Open API v3 — from https://www.etsy.com/developers/your-apps
# Etsy requires BOTH the keystring and shared secret, sent as
#   x-api-key: <keystring>:<shared_secret>
# Provide them as two vars (recommended)...
ETSY_API_KEY=your_etsy_keystring_here
ETSY_SHARED_SECRET=your_etsy_shared_secret_here
# ...or bundle them into one: ETSY_API_KEY=keystring:shared_secret  (leave ETSY_SHARED_SECRET unset)
